# A_OpenClaw - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Application
A_OPENCLAW_ENV=development

# LLM API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Adapter secrets (platform-specific)
# TELEGRAM_BOT_TOKEN=
# DISCORD_BOT_TOKEN=

# Optional — enables full results in the 'web_search' skill.
# Without it, web_search falls back to DuckDuckGo's Instant Answer API
# (well-known entities only). Get a free key at https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=
